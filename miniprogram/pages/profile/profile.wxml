<!-- 个人中心 -->
<view class="profile-page">
  <view class="page-navbar" style="padding-top: {{statusBarHeight}}px;">
    <text class="page-navbar-title">我的</text>
  </view>

  <!-- 用户信息头 -->
  <view class="user-header">
    <view class="user-avatar">
      <text class="avatar-emoji">👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">尊贵的打工人</text>
      <text class="user-id">ID: PureProfit User</text>
    </view>
  </view>

  <!-- 薪资概览卡片 -->
  <view class="salary-overview card" wx:if="{{isOnboarded}}">
    <view class="overview-row">
      <view class="overview-item">
        <text class="overview-label">月薪</text>
        <text class="overview-value">¥{{monthlySalary}}</text>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <text class="overview-label">时薪</text>
        <text class="overview-value">¥{{hourlyRate}}</text>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <text class="overview-label">秒薪</text>
        <text class="overview-value text-gold">¥{{secondRate}}</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item tap-active" bindtap="goSalarySetting">
      <view class="menu-left">
        <view class="menu-icon icon-salary">
          <text class="icon-text">💰</text>
        </view>
        <text class="menu-label">薪资设置</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item tap-active" bindtap="goTheme">
      <view class="menu-left">
        <view class="menu-icon icon-theme">
          <text class="icon-text">🎨</text>
        </view>
        <text class="menu-label">主题装扮</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item tap-active" bindtap="goReminder">
      <view class="menu-left">
        <view class="menu-icon icon-bell">
          <text class="icon-text">🔔</text>
        </view>
        <text class="menu-label">提醒偏好</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 危险操作区 -->
  <view class="danger-zone">
    <button class="btn-danger tap-active" bindtap="onClearData">清空全局数据</button>
  </view>

  <view class="footer">
    <text class="footer-text">纯利时刻 PureProfit v1.0.0</text>
  </view>
</view>
