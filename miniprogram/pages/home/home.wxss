.home-page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* ===== 空状态 ===== */
.empty-state {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-hint {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

/* ===== 导航栏 ===== */
.navbar {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 16rpx;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.nav-left {
  display: flex;
  align-items: center;
}

.logo-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #F97316, #FACC15);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 16rpx 40rpx rgba(249, 115, 22, 0.3),
    0 4rpx 12rpx rgba(249, 115, 22, 0.15);
  margin-right: 24rpx;
}

.logo-bolt {
  font-size: 44rpx;
}

.logo-text-group {
  display: flex;
  flex-direction: column;
}

.logo-text {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
  line-height: 1;
}

.engine-status {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #10B981;
  margin-right: 10rpx;
  box-shadow: 0 0 16rpx #10B981;
  animation: pulse 2s ease-in-out infinite;
}

.status-text {
  font-size: 18rpx;
  font-weight: 900;
  color: #059669;
  text-transform: uppercase;
  letter-spacing: 0.15em;
}

.nav-capsule-placeholder {
  width: 160rpx;
}

/* 问候条 */
.greeting-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(241, 245, 249, 0.5);
  backdrop-filter: blur(20rpx);
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

.greeting-left {
  display: flex;
  align-items: center;
}

.avatar-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 2rpx solid rgba(241, 245, 249, 1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.avatar-icon {
  font-size: 28rpx;
}

.greeting-text {
  font-size: 26rpx;
  font-weight: 900;
  color: rgba(51, 65, 85, 1);
}

.greeting-right {
  display: flex;
  align-items: center;
}

.setting-text {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 1);
}

.setting-arrow {
  font-size: 28rpx;
  color: rgba(148, 163, 184, 1);
  margin-left: 4rpx;
}

/* ===== 英雄区 ===== */
.hero-section {
  padding: 48rpx 32rpx 0;
  text-align: center;
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  background: rgba(255, 184, 0, 0.1);
  border-radius: 100rpx;
  border: 2rpx solid rgba(255, 184, 0, 0.2);
  margin-bottom: 32rpx;
}

.hero-pill-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.hero-pill-text {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(161, 118, 0, 1);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.hero-amount-wrapper {
  position: relative;
  display: inline-block;
  margin-bottom: 40rpx;
}

.hero-glow {
  position: absolute;
  inset: -60rpx;
  background: radial-gradient(circle, var(--color-gold-glow) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
}

.hero-amount {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.hero-currency {
  font-size: 56rpx;
  font-weight: 900;
  font-style: italic;
  color: var(--color-gold);
  margin-right: 8rpx;
}

.hero-number {
  font-size: 110rpx;
  font-weight: 900;
  color: var(--color-gold);
  letter-spacing: -0.04em;
  line-height: 1;
}

/* 收益分项 */
.earnings-split {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  margin: 0 8rpx;
}

.split-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.split-label {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 1);
  margin-bottom: 12rpx;
}

.split-label-green {
  color: #10B981;
  display: flex;
  align-items: center;
}

.ping-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #10B981;
  margin-left: 10rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.split-value {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
}

.split-value-green {
  font-size: 40rpx;
  color: #10B981;
}

.split-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(241, 245, 249, 1);
  margin: 0 16rpx;
}

/* ===== 月度累计 ===== */
.month-card {
  padding: 48rpx;
  margin-top: 32rpx;
  position: relative;
  overflow: hidden;
}

.month-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.month-left {
  display: flex;
  flex-direction: column;
}

.month-label {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 1);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 12rpx;
}

.month-amount {
  font-size: 52rpx;
  font-weight: 900;
  color: #FFFFFF;
  letter-spacing: -0.02em;
}

.month-badge {
  padding: 10rpx 20rpx;
  background: rgba(16, 185, 129, 0.2);
  border: 2rpx solid rgba(16, 185, 129, 0.3);
  border-radius: var(--radius-xs);
  backdrop-filter: blur(20rpx);
}

.badge-text {
  font-size: 22rpx;
  font-weight: 900;
  color: #34D399;
}

.month-progress-track {
  margin-top: 32rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 100rpx;
  overflow: hidden;
  padding: 3rpx;
}

.month-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FACC15, #34D399, #10B981);
  border-radius: 100rpx;
  box-shadow: 0 0 24rpx rgba(16, 185, 129, 0.5);
  transition: width 0.5s ease-out;
}

/* ===== 状态药丸 ===== */
.pills-container {
  display: flex;
  background: rgba(241, 245, 249, 0.8);
  padding: 8rpx;
  border-radius: var(--radius-lg);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
}

.state-pill {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 52rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 1);
  transition: all 0.3s ease;
}

.state-pill.active {
  background: #FFFFFF;
  box-shadow:
    0 8rpx 24rpx rgba(0, 0, 0, 0.05),
    0 2rpx 4rpx rgba(0, 0, 0, 0.02);
}

.state-pill.active.working { color: var(--color-dark); }
.state-pill.active.slacking { color: #059669; }
.state-pill.active.charging { color: #2563EB; }
.state-pill.active.sleeping { color: #DC2626; }

/* ===== 热力图 ===== */
.heatmap-section {
  margin-top: 16rpx;
}

.heatmap-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.heatmap-title {
  font-size: 24rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.heatmap-bar {
  height: 40rpx;
  display: flex;
  background: rgba(241, 245, 249, 1);
  border-radius: 24rpx;
  overflow: hidden;
  padding: 8rpx;
  border: 2rpx solid rgba(241, 245, 249, 1);
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.04);
}

.heat-seg {
  height: 100%;
  border-radius: 16rpx;
  min-width: 4%;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}

.heat-gap {
  width: 6rpx;
}

.heat-work { background: #1E293B; }
.heat-slack { background: #10B981; }
.heat-charge { background: #3B82F6; }
.heat-sleep { background: #F87171; flex: 1; }

.heatmap-legend {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 0 8rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.dot-work { background: #1E293B; }
.dot-slack { background: #10B981; }
.dot-charge { background: #3B82F6; }

.legend-text {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(100, 116, 139, 1);
  text-transform: uppercase;
}

/* ===== 倒计时矩阵 ===== */
.countdown-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.countdown-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 48rpx;
  background: linear-gradient(135deg, rgba(255, 250, 240, 0.5), rgba(255, 237, 213, 0.5));
  border-color: rgba(255, 237, 213, 0.5);
}

.countdown-main-left {
  display: flex;
  align-items: center;
}

.countdown-icon-box {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  background: #0F172A;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  box-shadow:
    0 16rpx 40rpx rgba(15, 23, 42, 0.15),
    0 4rpx 12rpx rgba(15, 23, 42, 0.08);
}

.countdown-icon {
  font-size: 48rpx;
  color: #FACC15;
}

.countdown-info {
  display: flex;
  flex-direction: column;
}

.countdown-label {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 1);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.countdown-time {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  letter-spacing: 4rpx;
  font-style: italic;
}

.progress-ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.ring-text {
  font-size: 24rpx;
  font-weight: 900;
  color: rgba(161, 118, 0, 1);
}

/* 底部双卡 */
.countdown-duo {
  display: flex;
  gap: 20rpx;
}

.duo-card {
  flex: 1;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.duo-green {
  background: rgba(236, 253, 245, 0.6);
  border-color: rgba(167, 243, 208, 0.3);
}

.duo-icon {
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.duo-label {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(148, 163, 184, 1);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 12rpx;
}

.duo-value-row {
  display: flex;
  align-items: baseline;
}

.duo-number {
  font-size: 64rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  letter-spacing: -0.04em;
  line-height: 1;
}

.duo-unit {
  font-size: 22rpx;
  font-weight: 900;
  color: rgba(203, 213, 225, 1);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-left: 12rpx;
}

.duo-hint {
  font-size: 36rpx;
  font-weight: 900;
  color: #059669;
  letter-spacing: -0.02em;
  line-height: 1.2;
}
