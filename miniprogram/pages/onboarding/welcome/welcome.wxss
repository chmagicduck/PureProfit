.welcome-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
  position: relative;
  overflow: hidden;
}

/* 顶部英雄区 */
.hero-area {
  flex: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.coin-placeholder {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB800, #FFCA28);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow:
    0 20rpx 60rpx rgba(255, 184, 0, 0.3),
    0 4rpx 20rpx rgba(255, 184, 0, 0.15);
}

.coin-inner {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFD54F, #FFB800);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.coin-symbol {
  font-size: 120rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.9);
  font-style: italic;
}

.coin-glow {
  position: absolute;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 184, 0, 0.15) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: -1;
}

/* 底部内容区 */
.content-area {
  flex: 4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 80rpx 120rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  letter-spacing: -0.02em;
}

.desc {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.4);
  margin-bottom: 80rpx;
}

.btn-start {
  width: 80%;
  background: var(--color-gold);
  color: #FFFFFF;
  border: none;
  border-radius: 100rpx;
  padding: 32rpx 0;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0.08em;
  box-shadow:
    0 16rpx 48rpx rgba(255, 184, 0, 0.35),
    0 4rpx 12rpx rgba(255, 184, 0, 0.2);
  animation: breathe 3s ease-in-out infinite;
}

.btn-start::after {
  border: none;
}
